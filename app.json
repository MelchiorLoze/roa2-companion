{
  "expo": {
    "name": "Rivals of Aether II Companion",
    "slug": "roa2-companion",
    "version": "2.4.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "roa2-companion",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0825",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cp0-mand4le.roa2companion"
    },
    "android": {
      "versionCode": 19,
      "package": "com.cp0_mand4le.roa2companion",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#0B0825"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/icon.png",
          "imageWidth": 200,
          "backgroundColor": "#0B0825"
        }
      ],
      [
        "expo-font",
        {
          "fonts": ["./src/assets/fonts"]
        }
      ],
      "expo-secure-store",
      "expo-image",
      ["expo-status-bar", { "style": "light", "hidden": false }],
      ["expo-navigation-bar", { "style": "light", "hidden": false, "enforceContrast": false }],
      ["expo-build-properties", { "android": { "usePrecompiledHeaders": true } }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
