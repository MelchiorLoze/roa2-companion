{
  "version": "2.3.0",
  "name": "roa2-companion",
  "private": true,
  "author": {
    "name": "Melchior Lozé",
    "email": "melchior.loze@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MelchiorLoze/roa2-companion"
  },
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "reset": "expo prebuild --clean",
    "test": "jest --randomize",
    "test:dev": "jest --randomize --watchAll",
    "test:update-snapshots": "jest --updateSnapshot",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --randomize",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "expo lint",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --strict --noEmit"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@shopify/react-native-skia)/"
    ],
    "testEnvironment": "@shopify/react-native-skia/jestEnv.js",
    "setupFiles": [
      "react-native-unistyles/mocks",
      "<rootDir>/src/unistyles.ts"
    ],
    "setupFilesAfterEnv": [
      "@shopify/react-native-skia/jestSetup.js",
      "<rootDir>/src/jest.setup.ts",
      "<rootDir>/src/jest.mock.ts"
    ],
    "clearMocks": true
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.2",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-query": "^5.100.7",
    "country-flag-icons": "^1.6.16",
    "expo": "^55.0.19",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.9",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-navigation-bar": "~55.0.12",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "fast-xml-builder": "^1.1.5",
    "fast-xml-parser": "^5.7.2",
    "luxon": "^3.7.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gifted-charts": "^1.4.76",
    "react-native-nitro-modules": "0.35.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-unistyles": "^3.2.4",
    "react-native-worklets": "0.7.4",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@leancodepl/resolve-eslint-flat-config": "^10.3.0",
    "@react-native-community/cli": "^17.0.1",
    "@react-native/eslint-config": "^0.85.2",
    "@tanstack/eslint-plugin-query": "^5.100.7",
    "@testing-library/react-native": "^13.3.3",
    "@types/country-flag-icons": "^1.2.2",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-native-unistyles": "^3.0.7",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "expo-dev-client": "~55.0.30",
    "fetch-mock": "^12.6.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "jest-fail-on-console": "^3.3.4",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1"
  },
  "overrides": {
    "eslint-plugin-ft-flow": "^3.0.11",
    "zod-validation-error": "^4.0.2"
  }
}
